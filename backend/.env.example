# Backend Environment Configuration

# Node Environment
NODE_ENV=production
# PORT is provided by Render in production; keep local fallback only.
PORT=8082

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/database

# Email Configuration (Resend SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_NAME=BihariCoder
EMAIL_FROM=noreply@biharicoder.com
REPLY_TO=noreply@biharicoder.com

# JWT Configuration
JWT_SECRET=replace-with-strong-random-secret

# CORS Configuration
CORS_ORIGIN=https://your-frontend.vercel.app
CLIENT_URL=https://your-frontend.vercel.app

# Internal API base URL (recommended on Render for multiplayer question fetches)
INTERNAL_API_BASE_URL=https://your-backend.onrender.com

# Groq AI Configuration
GROQ_API_KEY=your-groq-api-key

# Multiplayer Configuration
MATCH_TIMER=15
ELO_K_FACTOR=32

# BullMQ + Upstash Redis Configuration (Email Queue)
REDIS_URL=rediss://default:your-upstash-token@your-upstash-endpoint.upstash.io:6379
# Optional. If REDIS_URL already contains password/token, this can be omitted.
REDIS_TOKEN=your-upstash-token

# Single-service Render mode (run email worker in same process as API)
ENABLE_IN_PROCESS_EMAIL_WORKER=true

# Server Configuration
NODE_ENV=production
PORT=3000
PING_MESSAGE=Hello from Fusion!

# CORS Configuration (for production)
VITE_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database Configuration
DATABASE_URL=postgresql://username:password@db.host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Frontend Supabase Configuration (exposed to frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Authentication Secrets (Generate with: openssl rand -hex 32)
JWT_SECRET=generate_64_character_random_string_here
SESSION_SECRET=generate_64_character_random_string_here

# Multiplayer Features
MATCH_TIMER=15
ELO_K_FACTOR=32

# Groq AI Configuration
GROQ_API_KEY=gsk_your_api_key_here

# Optional: Error Tracking (e.g., Sentry)
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# Optional: Analytics
ANALYTICS_API_KEY=your_analytics_key_here

# Optional: CDN
CDN_URL=https://cdn.yourdomain.com

# Logging
LOG_LEVEL=info
